# Security & App Settings
SECRET_KEY=your_very_secure_random_string_here
FLASK_ENV=production
FLASK_DEBUG=0
APP_BASE_URL=https://kfms.arosoft.io

# MySQL Database
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root_secure_pass
MYSQL_DB=kiu_finance
MYSQL_USER=kiu_user
MYSQL_PASSWORD=kiu_secure_pass

# OTP email delivery.
# Gmail requires a Google App Password, not your normal account password.
MAIL_SERVER=mail.arosoft.io
MAIL_PORT=465
MAIL_USE_TLS=False
MAIL_USE_SSL=True
MAIL_USERNAME=kfms@arosoft.io
MAIL_PASSWORD=your_email_or_app_password_here
MAIL_DEFAULT_SENDER=kfms@arosoft.io
