# ─────────────────────────────────────────────────────────────
# KIU Financial Management System — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Flask
SECRET_KEY=change-me-to-a-long-random-secret-string
FLASK_ENV=development
FLASK_DEBUG=1

# MySQL Database (used inside Docker)
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=kiu_user
MYSQL_PASSWORD=kiu_secure_pass
MYSQL_DB=kiu_finance
MYSQL_ROOT_PASSWORD=root_secure_pass

# Email (optional — OTP prints to console if not set)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@kiu.ac.ug

# App
APP_BASE_URL=http://localhost:5000
